{
  "model": {
    "type": "logistic_regression",
    "max_iter": 500
  },
  "hpo": {
    "sampler": "tpe",
    "n_trials": 50,
    "metric": "f1",
    "direction": "maximize",
    "search_space": {
      "C": {
        "low": 0.001,
        "high": 100.0
      },
      "max_features": {
        "low": 1000,
        "high": 20000,
        "step": 500
      },
      "ngram_range": [
        "1,1",
        "1,2"
      ]
    },
    "cv_folds": 5
  },
  "seed": 42,
  "mlflow": {
    "tracking_uri": "http://127.0.0.1:5000",
    "experiment_name": "IMDB_HPO_Lab3",
    "register_model": true,
    "model_name": "IMDB_Sentiment",
    "stage": "Staging"
  },
  "data": {
    "train_path": "data/processed/train.csv",
    "test_path": "data/processed/test.csv"
  }
}
{
  "model": {
    "type": "logistic_regression",
    "max_iter": 500
  },
  "hpo": {
    "sampler": "grid",
    "n_trials": 20,
    "metric": "f1",
    "direction": "maximize",
    "search_space": {
      "C": [
        0.01,
        0.1,
        1.0,
        10.0
      ],
      "max_features": [
        1000,
        3000,
        5000,
        7000,
        9000,
        10000,
        11000,
        12000,
        13000,
        14000,
        15000,
        16000,
        17000,
        18000,
        19000,
        20000
      ],
      "ngram_range": [
        "1,1",
        "1,2"
      ]
    },
    "cv_folds": 5
  },
  "seed": 42,
  "mlflow": {
    "tracking_uri": "http://127.0.0.1:5000",
    "experiment_name": "IMDB_HPO_Lab3",
    "register_model": true,
    "model_name": "IMDB_Sentiment",
    "stage": "Staging"
  },
  "data": {
    "train_path": "data/processed/train.csv",
    "test_path": "data/processed/test.csv"
  }
}